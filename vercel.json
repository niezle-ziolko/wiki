{
    "public": true,
    "builds": [
        {
            "src": "wiki/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python",
                "pythonVersion": "3.10"
            }
        },
        {
          "src": "build.sh",
          "use": "@vercel/static-build",
          "config": {
            "distDir": "wiki/static"
          }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "wiki/wsgi.py"
        },
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        }
    ]
}