{
    "public": true,
    "builds": [
        {
            "src": "wiki/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3"
            }
        },
        {
            "src": "build.sh",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "encyclopedia/static"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "wiki/wsgi.py"
        },
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        }
    ],
    "build": {
        "env": {
            "PYTHON_VERSION": "3.12"
        },
        "commands": [
            "pip install -r requirements.txt",
            "pip install django-cf"
        ]
    }
}
